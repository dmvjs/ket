{
  "name": "@kirkelliott/ket",
  "version": "0.1.0",
  "type": "module",
  "description": "General-purpose quantum circuit simulator. Immutable TypeScript API, three backends, 14 import/export formats, zero dependencies.",
  "author": "kirkelliott",
  "license": "MIT",
  "keywords": ["quantum", "quantum-computing", "quantum-circuit", "qasm", "qiskit", "ionq", "simulation", "typescript"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ket.js",
      "default": "./dist/ket.js"
    }
  },
  "types": "dist/index.d.ts",
  "unpkg": "dist/ket.js",
  "module": "dist/ket.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && esbuild src/index.ts --bundle --format=esm --outfile=dist/ket.js",
    "test": "vitest run",
    "dev": "vitest"
  },
  "engines": { "node": ">=22" },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
